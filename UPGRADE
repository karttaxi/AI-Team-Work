def auto_attack(player, enemies, bullets, effects):
    now = pygame.time.get_ticks()

    # 냉기 장치 패시브: 일정 주기마다 적 둔화/정지 효과
    if player.freeze_skill and now - player.freeze_skill_last >= player.freeze_skill_delay:
        player.freeze_until = now + 1300
        player.freeze_skill_last = now

    for weapon in player.weapons:
        weapon.finish_reload_if_needed(now)

        if not weapon.ready_to_fire(now):
            continue

        if weapon.kind == "ranged":
            target = get_nearest_enemy(player.x, player.y, enemies)
            if target is None:
                continue

            angle = math.atan2(target.y - player.y, target.x - player.x)

            if weapon.id == "laser":
                # 레이저는 투사체를 만들지 않고, 플레이어 위치에서 즉시 직선으로 발사한다.
                end_x, end_y = get_line_end_from_player(player.x, player.y, angle)
                beam_half_width = 7

                final_level = get_final_weapon_level(weapon.id, weapon.level)
                for enemy in enemies:
                    hit_distance = distance_point_to_segment(
                        enemy.x, enemy.y,
                        player.x, player.y,
                        end_x, end_y
                    )
                    if hit_distance <= enemy.radius + beam_half_width:
                        if enemy.enemy_type in ("normal", "runner"):
                            # 레이저는 일반 적과 날쌘 적을 한 번에 절단한다.
                            enemy.take_damage(enemy.hp)
                        else:
                            enemy.take_damage(weapon.damage)
                            if final_level is not None and final_level >= 1:
                                # 최종 레이저는 빔 경로 위 적에게 추가 소각 피해
                                enemy.take_damage(int(weapon.damage * 0.35))

                effects.append(LaserBeamEffect(player.x, player.y, end_x, end_y, weapon.color))
                weapon.last_used = now
                continue

            if weapon.ammo <= 0:
                weapon.start_reload(now)
                continue

            pellet_count = getattr(weapon, "pellets", 1)
            spread = getattr(weapon, "spread", 0)
            for i in range(pellet_count):
                if pellet_count == 1:
                    shot_angle = angle
                else:
                    shot_angle = angle + spread * (i - (pellet_count - 1) / 2)
                vx = math.cos(shot_angle) * weapon.bullet_speed
                vy = math.sin(shot_angle) * weapon.bullet_speed

                bullets.append(
                    Bullet(
                        player.x,
                        player.y,
                        vx,
                        vy,
                        weapon.damage,
                        weapon.bullet_radius,
                        weapon.color,
                        weapon.pierce,
                        weapon.name,
                        getattr(weapon, "explosion_radius", 0),
                    )
                )

            weapon.ammo -= 1
            weapon.last_used = now

            if weapon.ammo <= 0:
                weapon.start_reload(now)

        else:
            # 근접 무기는 주변 범위 안의 모든 적을 자동 공격
            attacked = False
            for enemy in enemies:
                if distance(player.x, player.y, enemy.x, enemy.y) <= weapon.range + enemy.radius:
                    enemy.take_damage(weapon.damage)
                    attacked = True

            if attacked:
                effects.append(SlashEffect(player.x, player.y, weapon.range, weapon.color))
                if get_final_weapon_level(weapon.id, weapon.level) is not None:
                    # 최종 근접 무기는 충격파로 한 번 더 광역 피해
                    effects.append(ExplosionEffect(player.x, player.y, weapon.range + 28, weapon.color))
                    for enemy in enemies:
                        if distance(player.x, player.y, enemy.x, enemy.y) <= weapon.range + 35 + enemy.radius:
                            enemy.take_damage(int(weapon.damage * 0.30))
                weapon.last_used = now

def handle_bullet_collisions(bullets, enemies):
    for bullet in bullets[:]:
        bullet.update()

        if bullet.offscreen():
            if bullet in bullets:
                bullets.remove(bullet)
            continue

        for enemy in enemies[:]:
            if enemy.id in bullet.hit_enemies:
                continue

            if distance(bullet.x, bullet.y, enemy.x, enemy.y) < bullet.radius + enemy.radius:
                damage = bullet.damage
                if bullet.weapon_name == "전설 저격소총" and getattr(enemy, "enemy_type", "") == "boss":
                    damage = int(damage * 1.5)
                enemy.take_damage(damage)
                bullet.hit_enemies.add(enemy.id)

                # 유탄발사기는 관통 무기가 아니라, 맞은 지점 주변 적에게 폭발 피해를 준다.
                if bullet.explosion_radius > 0:
                    for splash_enemy in enemies:
                        if splash_enemy.id == enemy.id:
                            continue
                        if distance(enemy.x, enemy.y, splash_enemy.x, splash_enemy.y) <= bullet.explosion_radius + splash_enemy.radius:
                            splash_enemy.take_damage(int(bullet.damage * 0.65))
                    if bullet in bullets:
                        bullets.remove(bullet)
                    break

                # 최종/SF급 탄환은 작은 추가 충격 피해를 준다.
                if any(mark in bullet.weapon_name for mark in ["전설", "플라즈마", "차원", "오메가", "노바", "종말", "은하", "초신성", "가우스", "레일"]):
                    bonus_radius = 50
                    for splash_enemy in enemies:
                        if splash_enemy.id != enemy.id and distance(enemy.x, enemy.y, splash_enemy.x, splash_enemy.y) <= bonus_radius + splash_enemy.radius:
                            splash_enemy.take_damage(int(bullet.damage * 0.35))

                bullet.pierce -= 1

                if bullet.pierce <= 0 and bullet in bullets:
                    bullets.remove(bullet)

                break


def remove_dead_enemies(enemies, orbs, items, floating_texts, wave):
    kills = 0
    boss_killed = False

    for enemy in enemies[:]:
        if enemy.hp <= 0:
            if enemy.enemy_type == "boss":
                boss_killed = True
            orbs.append(ExpOrb(enemy.x, enemy.y, enemy.exp_amount, enemy.enemy_type))

            # 아이템 드롭: 전체적으로 훨씬 드물게 나오게 조정.
            # 방탄 조끼 강화 보급품(max_hp)은 제거했다.
            drop_chance = 0.025
            if enemy.enemy_type == "brute":
                drop_chance = 0.04
            elif enemy.enemy_type == "tank":
                drop_chance = 0.045
            elif enemy.enemy_type == "boss":
                drop_chance = 0.28

            if random.random() < drop_chance:
                item_type = random.choices(
                    ["heal", "magnet", "freeze"],
                    weights=[45, 25, 30],
                    k=1
                )[0]
                items.append(ItemDrop(enemy.x, enemy.y, item_type))

            enemies.remove(enemy)
            kills += 1

    return kills, boss_killed


def update_boss_patterns(enemies, player, effects):
    """보스 전용 패턴: 경고 원 이후 근거리 충격파, 가끔 잡몹 호출."""
    now = pygame.time.get_ticks()
    for enemy in enemies:
        if getattr(enemy, "enemy_type", None) != "boss":
            continue
        if not hasattr(enemy, "next_pattern_time"):
            enemy.next_pattern_time = now + 1200
        if now < enemy.next_pattern_time:
            continue

        pattern = random.choice(["shockwave", "shockwave", "shockwave", "summon", "rage"])
        if pattern == "shockwave":
            boss_day = get_chapter(enemy.wave if hasattr(enemy, "wave") else 1)
            # 보스 범위공격은 Day 4 범위를 최대치로 고정한다.
            # Day 1: 120, Day 2: 140, Day 3: 160, Day 4 이상: 180
            radius = min(180, 100 + min(boss_day, 4) * 20)
            # 후반 보스는 범위 대신 피해와 패턴 빈도로 압박한다.
            damage_bonus = 14 + max(0, boss_day - 4) * 2
            # 바로 피해를 주지 않고, 경고 원을 약 0.8초 보여준 뒤 터지게 한다.
            effects.append(BossWarningEffect(enemy.x, enemy.y, radius, damage=enemy.damage + damage_bonus, warning_frames=54, impact_frames=14))
        elif pattern == "summon":
            for _ in range(6 + min(9, get_chapter(enemy.wave if hasattr(enemy, "wave") else 1))):
                enemies.append(Enemy(max(1, getattr(enemy, "wave", 1))))
        else:
            # 광폭화: 짧은 시간 동안 보스가 더 빨라지고 단단해진다.
            enemy.speed *= 1.12
            enemy.damage += 2
            effects.append(BossWarningEffect(enemy.x, enemy.y, 95, damage=0, warning_frames=26, impact_frames=8))

        enemy.next_pattern_time = now + max(560, 2050 - get_chapter(getattr(enemy, "wave", 1)) * 180)


def spawn_enemy_if_needed(enemies, wave, spawn_timer, boss_spawned_waves, dt):
    spawn_timer += dt
    day = get_chapter(wave)
    # Day가 높아질수록 적 수가 약 10%씩 늘어나고, 생성 간격도 조금 빨라진다.
    interval = max(190, int((955 - wave * 48) * (0.95 ** (day - 1))))
    if day >= 6:
        interval = int(interval * 1.12)

    # 각 Day의 마지막 웨이브마다 보스 1회 소환
    if wave % WAVES_PER_DAY == 0 and wave not in boss_spawned_waves:
        enemies.append(Enemy(wave, forced_type="boss"))
        boss_spawned_waves.add(wave)
        return 0

    # 적이 너무 많아지는 것 방지. Day마다 최대 적 수 +10% 느낌으로 증가.
    max_enemies = min(118, int((25 + wave * 4) * (1 + 0.09 * (day - 1))))
    if len(enemies) >= max_enemies:
        return spawn_timer

    if spawn_timer >= interval:
        spawn_timer = 0
        enemies.append(Enemy(wave))

        # 후반부에는 가끔 2마리씩 등장
        if wave >= 1 and random.random() < min(0.36, 0.20 + day * 0.024):
            enemies.append(Enemy(wave))
        if day >= 3 and random.random() < min(0.16, 0.04 + day * 0.018):
            enemies.append(Enemy(wave))

    return spawn_timer


