def get_chapter(wave):
    # 4웨이브마다 다음 Day로 넘어감
    return (wave - 1) // WAVES_PER_DAY + 1


def get_day_wave(wave):
    # 전체 누적 웨이브를 Day 안의 웨이브 1~4 표시로 변환
    return (wave - 1) % WAVES_PER_DAY + 1


