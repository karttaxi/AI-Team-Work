def get_support_level(player, upgrade_id):
    return player.support_upgrade_levels.get(upgrade_id, 0)


def get_support_stage(upgrade_id, level):
    stages = SUPPORT_UPGRADE_STAGES.get(upgrade_id, [])
    if not stages:
        return None, None
    index = min(level, len(stages) - 1)
    return stages[index]


def get_support_upgrade_title(player, upgrade_id):
    title, _ = get_support_stage(upgrade_id, get_support_level(player, upgrade_id))
    return title


def get_support_upgrade_desc(player, upgrade_id):
    _, desc = get_support_stage(upgrade_id, get_support_level(player, upgrade_id))
    return desc


def get_weapon_upgrade_title(player, weapon_id):
    """업그레이드 창에 보여줄 무기 선택지 문구를 현재 보유/진화 상태에 맞춰 만든다."""
    current_weapon = None
    for weapon in player.weapons:
        if weapon.id == weapon_id:
            current_weapon = weapon
            break

    if current_weapon is None:
        return f"{get_weapon_evolution_name(weapon_id, 1) or WEAPON_DATA[weapon_id]['name']} 획득"

    current_name = current_weapon.name
    next_level = current_weapon.level + 1
    next_name = get_weapon_evolution_name(weapon_id, next_level) or current_name

    if next_name != current_name:
        return f"{current_name} → {next_name}"

    final_level = get_final_weapon_level(weapon_id, current_weapon.level) or 1
    return f"{current_name} Lv.{final_level} → Lv.{final_level + 1}"


def get_upgrade_description(player, choice):
    """업그레이드 창 설명을 현재 상태 기준으로 최대한 정확하게 보여준다."""
    weapon_id = choice.get("weapon_id")
    if weapon_id:
        for weapon in player.weapons:
            if weapon.id == weapon_id:
                next_name = get_weapon_evolution_name(weapon_id, weapon.level + 1) or weapon.name
                if next_name != weapon.name:
                    return f"무기 이름 변경 + 공격력/공속/탄창·사거리 등 대폭 강화"
                return "최종 단계 무기 강화 레벨 +1. 전설 무기 효과와 능력치가 상승"
        return WEAPON_DATA[weapon_id]["desc"]

    support_desc = get_support_upgrade_desc(player, choice.get("id"))
    if support_desc:
        return support_desc

    return choice["desc"]


