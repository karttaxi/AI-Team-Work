def get_weapon_evolution_name(weapon_id, weapon_level):
    """무기 레벨에 맞는 진화 이름을 반환한다. 1레벨부터 1단계씩 진화한다."""
    names = WEAPON_EVOLUTIONS.get(weapon_id, [])
    if not names:
        return None
    index = min(max(weapon_level - 1, 0), len(names) - 1)
    return names[index]


def is_final_weapon_stage(weapon_id, weapon_level):
    names = WEAPON_EVOLUTIONS.get(weapon_id, [])
    return bool(names) and weapon_level >= len(names)


def get_final_weapon_level(weapon_id, weapon_level):
    """최종 진화 무기부터 화면에 표시할 강화 레벨. 최종 무기 도달 시 Lv.1이다."""
    names = WEAPON_EVOLUTIONS.get(weapon_id, [])
    if not names or weapon_level < len(names):
        return None
    return weapon_level - len(names) + 1


def get_weapon_display_name(weapon):
    final_level = get_final_weapon_level(weapon.id, weapon.level)
    if final_level is None:
        return weapon.name
    return f"{weapon.name} Lv.{final_level}"




