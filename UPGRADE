def apply_day_reward(player, reward_id, day):
    if reward_id == "heal":
        amount = int(player.max_hp * 0.45)
        player.hp = min(player.max_hp, player.hp + amount)
        return f"Day 보상: 체력 {amount} 회복"
    if reward_id == "armor":
        player.armor += 2
        player.max_hp += 15
        player.hp = min(player.max_hp, player.hp + 25)
        return "Day 보상: 방탄 보강, 피해 감소 +2"
    if reward_id == "exp":
        bonus = DAY_BONUS_EXP_BASE + day * 80
        player.exp += bonus
        return f"Day 보상: 추가 경험치 +{bonus}"
    if reward_id == "weapon":
        if player.weapons:
            weapon = random.choice(player.weapons)
            result = weapon.upgrade()
            player.evolution_flash_until = pygame.time.get_ticks() + 1200
            return f"Day 보상: {result} 강화"
    if reward_id == "speed":
        player.speed += 0.35
        return "Day 보상: 이동속도 +0.35"
    return "Day 보상 획득"


