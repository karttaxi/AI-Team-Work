        self.y = y
        self.vx = vx
        self.vy = vy
        self.damage = damage
        self.radius = radius
        self.color = color
        self.pierce = pierce
        self.weapon_name = weapon_name
        self.explosion_radius = explosion_radius
        self.hit_enemies = set()

    def update(self):
        self.x += self.vx
        self.y += self.vy

    def offscreen(self):
        return self.x < -40 or self.x > WIDTH + 40 or self.y < -40 or self.y > HEIGHT + 40

    def draw(self, surface):
        if self.weapon_name == "수리검":
            pygame.draw.circle(surface, WHITE, (int(self.x), int(self.y)), self.radius, 1)
        else:
            pygame.draw.circle(surface, self.color, (int(self.x), int(self.y)), self.radius)

class Enemy:
    next_id = 1

    def __init__(self, wave, forced_type=None):
        self.id = Enemy.next_id
        self.wave = wave
        Enemy.next_id += 1

        enemy_type = forced_type or random.choices(
            ["normal", "runner", "brute", "tank"],
            # 강한 적은 더 희귀하게, 대신 훨씬 위협적인 정예 개체로 만든다.
            weights=[48, 32, 7, 13],
            k=1
        )[0]

        self.enemy_type = enemy_type
        self.spawn_at_edge()

        # 전체 난이도 상승: Day가 오를수록 체력/속도/피해가 더 빠르게 증가한다.
        day = get_chapter(wave)
        # 난이도 살짝 완화: 기존보다 체력 증가폭을 조금 낮춘다.
        scale = 1 + wave * 0.17 + day * 0.065 + max(0, 4 - day) * 0.07

        # DAY가 올라갈수록 적 하나당 경험치가 확실히 증가한다.
        # 빠른 적은 낮게, 일반/강한/탱커/보스 순서로 보상을 크게 다르게 설정.
        exp_scale = 1 + max(0, day - 1) * 0.55 + max(0, wave - 1) * 0.12

        if enemy_type == "runner":
            self.name = "날쌘 적"
            self.radius = 12
            self.max_hp = int((29 + wave * 7) * scale)
            self.speed = 2.75 + wave * 0.085 + day * 0.03
            self.damage = 10 + wave // 4 + day // 2
            self.color = YELLOW
            base_exp = 28
        elif enemy_type == "brute":
            self.name = "강한 적"
            self.radius = 26
            # 잘 안 나오는 대신 탱커보다 전투 위협도가 높다.
            self.max_hp = int((145 + wave * 25) * scale)
            self.speed = 1.50 + wave * 0.065 + day * 0.03
            self.damage = 32 + wave + day
            self.color = ORANGE
            # 탱커보다 더 많은 경험치를 준다.
            base_exp = 180
        elif enemy_type == "tank":
            self.name = "샌드백"
            self.radius = 28
            self.max_hp = int((165 + wave * 22) * scale)
            self.speed = 0.74 + wave * 0.026 + day * 0.012
            self.damage = 14 + wave // 4 + day // 2
            self.color = GREEN
            base_exp = 135
        elif enemy_type == "boss":
            self.name = "보스"
            self.radius = 50
            # 보스전이 확실한 벽처럼 느껴지도록 체력을 크게 올린다.
            self.max_hp = int((1750 + wave * 420) * (1 + day * 0.16))
            self.speed = 1.22 + wave * 0.036 + day * 0.028
            self.damage = 40 + wave + day * 2
            self.color = PURPLE
            base_exp = 820
        else:
            self.name = "일반 적"
            self.radius = 18
            self.max_hp = int((60 + wave * 11) * scale)
            self.speed = 1.55 + wave * 0.048 + day * 0.018
            self.damage = 14 + wave // 4 + day // 2
            self.color = RED
            base_exp = 55

        # 중후반 난이도 완화: 전설 무기 파워를 체감할 수 있게 Day 4 이후 성장폭을 낮춘다.
        if day >= 4:
            self.max_hp = int(self.max_hp * 0.90)
        if day >= 5:
            self.damage = max(1, int(self.damage * 0.90))
        if day >= 6:
            self.max_hp = int(self.max_hp * 0.92)
            self.speed *= 0.95
        if enemy_type == "boss" and day >= 6:
            # 중후반 전체 난이도 완화는 유지하되, 보스만은 너무 약해지지 않게 보정한다.
            self.max_hp = int(self.max_hp * 1.08)
            self.damage = max(1, int(self.damage * 0.98))
        if enemy_type == "tank" and day >= 4:
            self.max_hp = int(self.max_hp * 0.90)

        self.exp_amount = int((base_exp + day * 18 + wave * 6) * exp_scale)
        if day >= 4:
            self.exp_amount = int(self.exp_amount * 1.12)
        self.hp = self.max_hp

    def spawn_at_edge(self):
        side = random.randint(0, 3)
        margin = 50

        if side == 0:
            self.x = -margin
            self.y = random.randint(0, HEIGHT)
        elif side == 1:
            self.x = WIDTH + margin
            self.y = random.randint(0, HEIGHT)
        elif side == 2:
            self.x = random.randint(0, WIDTH)
            self.y = -margin
        else:
            self.x = random.randint(0, WIDTH)
            self.y = HEIGHT + margin

    def update(self, player, frozen=False):
        speed = self.speed * (0.18 if frozen else 1.0)
        angle = math.atan2(player.y - self.y, player.x - self.x)
        self.x += math.cos(angle) * speed
        self.y += math.sin(angle) * speed

    def take_damage(self, damage):
        self.hp -= damage

    def draw(self, surface):
        pygame.draw.circle(surface, self.color, (int(self.x), int(self.y)), self.radius)
        pygame.draw.circle(surface, WHITE, (int(self.x), int(self.y)), self.radius, 2)

        if self.enemy_type == "runner":
            pygame.draw.circle(surface, BLACK, (int(self.x), int(self.y)), max(3, self.radius // 3))
        elif self.enemy_type == "tank":
            pygame.draw.rect(surface, BLACK, (int(self.x - 8), int(self.y - 8), 16, 16))
        elif self.enemy_type == "boss":
            draw_text(surface, "BOSS", SMALL_FONT, WHITE, int(self.x - 24), int(self.y - 8))

        # 체력바
        ratio = clamp(self.hp / self.max_hp, 0, 1)
        bar_w = max(42, self.radius * 2)
        bar_h = 6
        bx = int(self.x - bar_w / 2)
        by = int(self.y - self.radius - 14)
        pygame.draw.rect(surface, GRAY, (bx, by, bar_w, bar_h))
        pygame.draw.rect(surface, GREEN, (bx, by, int(bar_w * ratio), bar_h))


class ExpOrb:
    def __init__(self, x, y, amount, enemy_type="normal"):
        self.x = x
        self.y = y
        self.amount = amount
        self.enemy_type = enemy_type
        self.pulse = random.random() * math.pi * 2

        # 적 종류별 경험치 구슬 외형을 다시 정리한다.
        # 경험치 가치가 높을수록 더 크고, 테두리/문양이 뚜렷하게 보인다.
        styles = {
            "runner": {"radius": 5, "color": YELLOW, "outline": DARK_GRAY, "mark": ">"},
            "normal": {"radius": 7, "color": GREEN, "outline": WHITE, "mark": ""},
            "tank": {"radius": 10, "color": CYAN, "outline": GREEN, "mark": "■"},
            "brute": {"radius": 13, "color": ORANGE, "outline": RED, "mark": "!"},
            "boss": {"radius": 17, "color": PURPLE, "outline": YELLOW, "mark": "★"},
        }
        style = styles.get(enemy_type, styles["normal"])
        self.radius = style["radius"]
        self.color = style["color"]
        self.outline = style["outline"]
        self.mark = style["mark"]

    def update(self, player):
        now = pygame.time.get_ticks()
        attract_range = player.magnet_range

        if now < player.magnet_boost_until:
            attract_range = 2000

        d = distance(self.x, self.y, player.x, player.y)
        if d < attract_range and d > 0:
            speed = 4.5 + (attract_range - min(d, attract_range)) / 80
            self.x += (player.x - self.x) / d * speed
            self.y += (player.y - self.y) / d * speed

    def draw(self, surface):
        x, y = int(self.x), int(self.y)
        now = pygame.time.get_ticks()
        pulse_size = 1 if int(now / 220 + self.pulse) % 2 == 0 else 0

        pygame.draw.circle(surface, self.color, (x, y), self.radius + pulse_size)
        pygame.draw.circle(surface, self.outline, (x, y), self.radius + pulse_size, 2)

        if self.enemy_type == "runner":
            pygame.draw.line(surface, self.outline, (x - 3, y), (x + 4, y), 2)
        elif self.enemy_type == "normal":
            pygame.draw.circle(surface, WHITE, (x, y), 2)
        elif self.enemy_type == "tank":
            pygame.draw.rect(surface, self.outline, (x - 5, y - 5, 10, 10), 2)
        elif self.enemy_type == "brute":
            # 강한 적 구슬은 탱커보다 가치가 높다는 걸 눈으로 알 수 있게 붉은 정예 문양을 넣는다.
            pygame.draw.circle(surface, RED, (x, y), max(3, self.radius // 2), 2)
            draw_text(surface, "!", SMALL_FONT, WHITE, x - 3, y - 10)
        elif self.enemy_type == "boss":
            pygame.draw.circle(surface, self.outline, (x, y), self.radius + 5, 2)
            draw_text(surface, "★", SMALL_FONT, WHITE, x - 6, y - 10)

class ItemDrop:
    def __init__(self, x, y, item_type):
        self.x = x
        self.y = y
        self.type = item_type
        # 아이템이 경험치 구슬이나 배경에 묻히지 않도록 더 크게 표시한다.
        self.radius = 15
        self.spawn_time = pygame.time.get_ticks()

    def apply(self, player):
        now = pygame.time.get_ticks()

        if self.type == "heal":
            player.hp = min(player.max_hp, player.hp + 35)
            return "구급상자로 체력 회복"
        if self.type == "magnet":
            player.magnet_boost_until = now + 4500
            return "구조 신호기 작동"
        if self.type == "freeze":
            player.freeze_until = now + 3200
            return "섬광탄 폭발! 좀비 일시정지"
        return "보급품 획득"

    def draw(self, surface):
        if self.type == "heal":
            color = RED
            label = "+"
            name = "구급"
        elif self.type == "magnet":
            color = CYAN
            label = "S"
            name = "신호"
        elif self.type == "freeze":
            color = BLUE
            label = "!"
            name = "섬광"
        else:
            color = WHITE
            label = "?"
            name = "보급"

        x, y = int(self.x), int(self.y)
        now = pygame.time.get_ticks()
        pulse = 2 + int((math.sin(now / 130) + 1) * 2)

        # 바깥 광원 + 진한 테두리 + 내부 아이콘으로 멀리서도 아이템임을 알 수 있게 한다.
        pygame.draw.circle(surface, color, (x, y), self.radius + 8 + pulse, 2)
        pygame.draw.circle(surface, BLACK, (x, y), self.radius + 3)
        pygame.draw.circle(surface, color, (x, y), self.radius)
        pygame.draw.circle(surface, WHITE, (x, y), self.radius, 2)
        pygame.draw.rect(surface, WHITE, (x - 8, y - 8, 16, 16), 2, border_radius=3)
        draw_text(surface, label, SMALL_FONT, WHITE, x - 5, y - 11)
        draw_text(surface, name, SMALL_FONT, color, x - 16, y + 16)


class LaserBeamEffect:
    def __init__(self, start_x, start_y, end_x, end_y, color):
