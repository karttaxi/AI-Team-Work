class Weapon:
    def __init__(self, weapon_id):
        data = deepcopy(WEAPON_DATA[weapon_id])
        self.id = weapon_id
        self.name = data["name"]
        self.kind = data["kind"]
        self.level = 1
        self.damage = data["damage"]
        self.cooldown = data["cooldown"]
        self.color = data["color"]
        self.last_used = 0

        if self.kind == "ranged":
            self.bullet_speed = data["bullet_speed"]
            self.bullet_radius = data["bullet_radius"]
            self.unlimited_ammo = data.get("unlimited_ammo", False)
            self.max_ammo = data["max_ammo"]
            self.ammo = self.max_ammo
            self.reload_time = data["reload_time"]
            self.reload_end_time = 0
            self.pierce = data["pierce"]
            self.pellets = data.get("pellets", 1)
            self.spread = data.get("spread", 0)
            self.explosion_radius = data.get("explosion_radius", 0)
        else:
            self.range = data["range"]

    def upgrade(self):
        old_name = self.name
        old_final_level = get_final_weapon_level(self.id, self.level)
        self.level += 1

        # 무기 레벨이 1 오를 때마다 이름도 1단계 진화한다.
        # 최종 이름에 도달한 뒤에는 이름은 유지되고 최종 강화 Lv만 오른다.
        evolved_name = get_weapon_evolution_name(self.id, self.level)
        if evolved_name:
            self.name = evolved_name

        # 눈으로 체감될 만큼 강하게 상승시킨다.
        self.damage = int(self.damage * 1.28) + 6
        self.cooldown = max(45, int(self.cooldown * 0.86))

        if self.kind == "ranged":
            if self.unlimited_ammo:
                # 레이저는 투사체가 아니라 즉시 뻗는 빔이라 탄속/장전 개념이 없다.
                self.pierce = 999999
                self.damage = int(self.damage * 1.12)
            else:
                self.max_ammo += 5
                self.ammo = self.max_ammo
                self.reload_time = max(300, int(self.reload_time * 0.86))
                self.bullet_speed += 1
                self.bullet_radius = min(13, self.bullet_radius + 1)
                self.pierce += 1
                if self.id == "sniper":
                    self.pierce += 1
                    self.damage = int(self.damage * 1.08)

                if hasattr(self, "pellets") and self.pellets > 1 and self.level % 2 == 0:
                    self.pellets += 1
                    self.spread = min(0.55, self.spread + 0.03)
                if hasattr(self, "explosion_radius") and self.explosion_radius > 0:
                    self.explosion_radius += 14
        else:
            self.range += 9

        # 전설 무기에 처음 도달하는 순간, 무기별 고유 전설 효과를 1회 적용한다.
        if old_final_level is None and get_final_weapon_level(self.id, self.level) is not None:
            self.apply_legendary_bonus_once()

        if old_name != self.name:
            return f"{old_name} → {self.name}"

        new_final_level = get_final_weapon_level(self.id, self.level)
        if new_final_level is not None:
            before = old_final_level or 1
            return f"{self.name} Lv.{before} → Lv.{new_final_level}"

        return self.name

    def apply_legendary_bonus_once(self):
        """전설 단계에 처음 도달했을 때만 무기별 고유 효과를 적용한다."""
        if self.kind == "ranged":
            if self.id == "gun":
                # 전설 권총: 탄창 3배, 재장전 80% 감소
                self.max_ammo *= 3
                self.ammo = self.max_ammo
                self.reload_time = max(120, int(self.reload_time * 0.20))
            elif self.id == "rifle":
                # 전설 소총: 탄창 2배, 관통 +1
                self.max_ammo *= 2
                self.ammo = self.max_ammo
                self.pierce += 1
            elif self.id == "shotgun":
                # 전설 산탄총: 산탄 수 증가, 재장전 70% 감소
                self.pellets = max(getattr(self, "pellets", 1) + 3, 9)
                self.spread = min(0.62, getattr(self, "spread", 0.34) + 0.08)
                self.reload_time = max(180, int(self.reload_time * 0.30))
                self.max_ammo += 10
                self.ammo = self.max_ammo
            elif self.id == "sniper":
                # 전설 저격소총: 관통 10, 보스 추가 피해는 충돌 처리에서 적용
                self.pierce = max(self.pierce, 10)
                self.reload_time = max(450, int(self.reload_time * 0.65))
            elif self.id == "minigun":
                # 전설 중기관총: 초대형 탄창, 재장전 거의 없음
                self.max_ammo = max(self.max_ammo * 3, 320)
                self.ammo = self.max_ammo
                self.reload_time = max(160, int(self.reload_time * 0.15))
            elif self.id == "grenade_launcher":
                # 전설 유탄발사기: 폭발 범위 2배
                self.explosion_radius = max(getattr(self, "explosion_radius", 0) * 2, 180)
                self.max_ammo += 6
                self.ammo = self.max_ammo
            elif self.id == "flamethrower":
                # 전설 화염방사기: 화염 지속/관통 느낌 강화
                self.pierce += 3
                self.max_ammo += 80
                self.ammo = self.max_ammo
                self.cooldown = max(35, int(self.cooldown * 0.75))
            elif self.id == "laser":
                # 전설 레이저: 무한 탄약 + 무한 관통
                self.unlimited_ammo = True
                self.pierce = 999999
                self.reload_time = 0
                self.max_ammo = 999999
                self.ammo = self.max_ammo
        else:
            # 전설 근접 무기: 사거리와 피해 체감 상승
            self.range += 22
            self.damage = int(self.damage * 1.25)

    def ready_to_fire(self, now):
        return now - self.last_used >= self.cooldown

    def is_reloading(self, now):
        return self.kind == "ranged" and not self.unlimited_ammo and self.reload_end_time > now

    def start_reload(self, now):
        if self.kind == "ranged" and not self.unlimited_ammo and self.reload_end_time <= now:
            self.reload_end_time = now + self.reload_time

    def finish_reload_if_needed(self, now):
        if self.kind == "ranged" and not self.unlimited_ammo and self.reload_end_time > 0 and now >= self.reload_end_time:
            self.ammo = self.max_ammo
            self.reload_end_time = 0


class Player:
    def __init__(self):
        self.x = WIDTH // 2
        self.y = HEIGHT // 2
        self.radius = 18
        self.speed = 4.8
        self.hp = 120
        self.max_hp = 120
        self.armor = 0
        self.armor_level = 0
        self.level = 1
        self.exp = 0
        self.exp_needed = 75
        self.magnet_range = 85
        self.last_hit = 0
        self.hit_delay = 650
        self.weapons = [Weapon("gun")]
        self.freeze_skill = False
        self.freeze_skill_last = 0
        self.freeze_skill_delay = 9000
        self.support_upgrade_levels = {
            "ammo_all": 0,
            "max_hp": 0,
            "move_speed": 0,
            "magnet": 0,
            "freeze_skill": 0,
            "heal": 0,
        }

        # 아이템 효과 시간
        self.magnet_boost_until = 0
        self.freeze_until = 0
        self.evolution_flash_until = 0
        self.day_reward_count = 0

    def move(self, keys):
        dx = 0
        dy = 0

        if keys[pygame.K_w] or keys[pygame.K_UP]:
            dy -= 1
        if keys[pygame.K_s] or keys[pygame.K_DOWN]:
            dy += 1
        if keys[pygame.K_a] or keys[pygame.K_LEFT]:
            dx -= 1
        if keys[pygame.K_d] or keys[pygame.K_RIGHT]:
            dx += 1

        length = math.hypot(dx, dy)
        if length > 0:
            dx /= length
            dy /= length

        self.x += dx * self.speed
        self.y += dy * self.speed
        self.x = clamp(self.x, self.radius, WIDTH - self.radius)
        self.y = clamp(self.y, self.radius, HEIGHT - self.radius)

    def take_damage(self, damage):
        now = pygame.time.get_ticks()

        if now - self.last_hit >= self.hit_delay:
            # 방탄 조끼: 강화할수록 모든 접촉 피해를 직접 줄인다.
            # 최소 1 피해는 받게 해서 완전 무적이 되지는 않게 한다.
            final_damage = max(1, damage - self.armor)
            self.hp = max(0, self.hp - final_damage)
            self.last_hit = now

    def gain_exp(self, amount):
        self.exp += amount
        leveled = False

        while self.exp >= self.exp_needed:
            self.exp -= self.exp_needed
            self.level += 1
            self.exp_needed = int(self.exp_needed * 1.24 + 18)
            leveled = True

        return leveled

    def add_or_upgrade_weapon(self, weapon_id):
        for weapon in self.weapons:
            if weapon.id == weapon_id:
                upgrade_result = weapon.upgrade()
                return f"{upgrade_result} 강화"

        self.weapons.append(Weapon(weapon_id))
        return f"{get_weapon_evolution_name(weapon_id, 1) or WEAPON_DATA[weapon_id]['name']} 획득"

    def apply_upgrade(self, upgrade_id):
        for choice in UPGRADE_POOL:
            if choice.get("id") == upgrade_id and "weapon_id" in choice:
                result = self.add_or_upgrade_weapon(choice["weapon_id"])
                self.evolution_flash_until = pygame.time.get_ticks() + 1200
                return result

        if upgrade_id == "damage_all":
            for weapon in self.weapons:
                if weapon.kind == "ranged":
                    weapon.damage += 6
            return "원거리 무기 공격력 증가"

        if upgrade_id == "melee_damage":
            for weapon in self.weapons:
                if weapon.kind == "melee":
                    weapon.damage += 8
            return "근접 무기 공격력 증가"

        if upgrade_id == "cooldown_all":
            for weapon in self.weapons:
                weapon.cooldown = max(50, int(weapon.cooldown * 0.88))
            return "생존 전투 속도 증가"

        if upgrade_id == "ammo_all":
            level = self.support_upgrade_levels.get("ammo_all", 0)
            bonus = 6 + min(level, 4)
            for weapon in self.weapons:
                if weapon.kind == "ranged" and not weapon.unlimited_ammo:
                    weapon.max_ammo += bonus
                    weapon.ammo = weapon.max_ammo
            title = get_support_upgrade_title(self, "ammo_all")
            self.support_upgrade_levels["ammo_all"] = level + 1
            return f"{title}: 탄창 +{bonus}"

        if upgrade_id == "reload_all":
            for weapon in self.weapons:
                if weapon.kind == "ranged" and not weapon.unlimited_ammo:
                    weapon.reload_time = max(350, int(weapon.reload_time * 0.75))
            return "탄창 교체 속도 증가"

        if upgrade_id == "projectile_speed":
            for weapon in self.weapons:
                if weapon.kind == "ranged" and not weapon.unlimited_ammo:
                    weapon.bullet_speed += 2
            return "고압 탄약 장착"

        if upgrade_id == "max_hp":
            level = self.support_upgrade_levels.get("max_hp", 0)
            title = get_support_upgrade_title(self, "max_hp")
            hp_bonus = 20 + min(level // 2, 3) * 5
            heal_bonus = 25 + min(level // 2, 3) * 5
            self.armor_level += 1
            armor_bonus = 3 + (1 if level >= 3 else 0)
            self.armor += armor_bonus
            self.max_hp += hp_bonus
            self.hp = min(self.max_hp, self.hp + heal_bonus)
            self.support_upgrade_levels["max_hp"] = level + 1
            return f"{title}: 최대체력 +{hp_bonus}, 피해 감소 +{armor_bonus} / 현재 {self.armor}"

        if upgrade_id == "move_speed":
            level = self.support_upgrade_levels.get("move_speed", 0)
            title = get_support_upgrade_title(self, "move_speed")
            speed_bonus = 0.45 + min(level, 4) * 0.05
            self.speed += speed_bonus
            self.support_upgrade_levels["move_speed"] = level + 1
            return f"{title}: 이동속도 +{speed_bonus:.2f}"

        if upgrade_id == "magnet":
            level = self.support_upgrade_levels.get("magnet", 0)
            title = get_support_upgrade_title(self, "magnet")
            bonus = 45 + min(level, 4) * 10
            self.magnet_range += bonus
            self.support_upgrade_levels["magnet"] = level + 1
            return f"{title}: 흡수 범위 +{bonus}"

        if upgrade_id == "freeze_skill":
            level = self.support_upgrade_levels.get("freeze_skill", 0)
            title = get_support_upgrade_title(self, "freeze_skill")
            self.freeze_skill = True
            self.freeze_skill_delay = max(4500, self.freeze_skill_delay - 1200)
            self.support_upgrade_levels["freeze_skill"] = level + 1
            return f"{title}: 재사용 대기시간 감소"

        if upgrade_id == "heal":
            self.hp = min(self.max_hp, self.hp + 60)
            return "구급상자로 체력 회복"

        return "업그레이드 적용"

    def draw(self, surface):
        pygame.draw.circle(surface, BLUE,(int(self.x), int(self.y)), self.radius)

        # 무기 진화/최종 강화 직후 눈에 보이는 에너지 이펙트
        now = pygame.time.get_ticks()
        if now < self.evolution_flash_until:
            pulse = 4 + ((self.evolution_flash_until - now) // 80) % 8
            pygame.draw.circle(surface, CYAN, (int(self.x), int(self.y)), self.radius + 10 + pulse, 3)
            pygame.draw.circle(surface, YELLOW, (int(self.x), int(self.y)), self.radius + 22 + pulse, 1)

        # 피격 직후 짧게 테두리 표시
        if now - self.last_hit < 160:
            pygame.draw.circle(surface, RED, (int(self.x), int(self.y)), self.radius + 5, 2)


class Bullet:
    def __init__(self, x, y, vx, vy, damage, radius, color, pierce, weapon_name, explosion_radius=0):
