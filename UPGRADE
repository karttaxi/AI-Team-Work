class BossWarningEffect:
    def __init__(self, x, y, radius, damage=0, warning_frames=48, impact_frames=14):
        self.x = x
        self.y = y
        self.radius = radius
        self.damage = damage
        self.warning_frames = warning_frames
        self.impact_frames = impact_frames
        self.life = warning_frames + impact_frames
        self.triggered = False

    def update(self, player=None):
        # 먼저 바닥 경고 표시를 충분히 보여준 뒤, 마지막 짧은 순간에만 실제 피해를 준다.
        if not self.triggered and self.life <= self.impact_frames:
            self.triggered = True
            if self.damage > 0 and player is not None:
                if distance(player.x, player.y, self.x, self.y) <= self.radius + player.radius:
                    player.take_damage(self.damage)
        self.life -= 1

    def draw(self, surface):
        if self.life <= 0:
            return

        center = (int(self.x), int(self.y))
        if not self.triggered:
            # 예고 단계: 붉은 위험 범위 + 안쪽으로 모이는 충전 원
            progress = 1 - (self.life - self.impact_frames) / max(1, self.warning_frames)
            progress = clamp(progress, 0, 1)
            pygame.draw.circle(surface, RED, center, int(self.radius), 3)
            pygame.draw.circle(surface, YELLOW, center, int(self.radius * progress), 2)
            pygame.draw.line(surface, RED, (int(self.x - self.radius), int(self.y)), (int(self.x + self.radius), int(self.y)), 1)
            pygame.draw.line(surface, RED, (int(self.x), int(self.y - self.radius)), (int(self.x), int(self.y + self.radius)), 1)
            draw_text(surface, "위험!", SMALL_FONT, YELLOW, int(self.x), int(self.y - self.radius - 26), center=True)
        else:
            # 폭발 단계: 실제 공격이 터졌다는 것을 짧게 보여준다.
            flash_radius = int(self.radius * (0.75 + 0.25 * self.life / max(1, self.impact_frames)))
            pygame.draw.circle(surface, ORANGE, center, flash_radius, 5)
            pygame.draw.circle(surface, YELLOW, center, max(8, flash_radius // 3), 2)


