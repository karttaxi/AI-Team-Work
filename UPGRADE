def get_font(size):
    """윈도우에서는 맑은 고딕을 우선 사용한다. 없으면 기본 폰트 사용."""
    candidates = ["malgungothic", "맑은 고딕", "gulim", "arialunicode", "consolas"]

    for name in candidates:
        font = pygame.font.SysFont(name, size)
        if font is not None:
            return font

    return pygame.font.Font(None, size)


