        self.start_y = start_y
        self.end_x = end_x
        self.end_y = end_y
        self.color = color
        self.life = 12

    def update(self):
        self.life -= 1

    def draw(self, surface):
        if self.life <= 0:
            return

        # 끝 원 없이, 플레이어 몸에서 시작해 화면 끝까지 뻗는 완전한 직선 빔
