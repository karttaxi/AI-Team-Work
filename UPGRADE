def reset_game():
    player = Player()
    enemies = []
    bullets = []
    orbs = []
    items = []
    effects = []
    floating_texts = []
    wave = 1
    chapter = get_chapter(wave)
    kills = 0
    next_wave_kills = 20
    spawn_timer = 0
    boss_spawned_waves = set()
    message = "녹슨 권총으로 시작합니다"
    message_until = pygame.time.get_ticks() + 2400

    return {
        "player": player,
        "enemies": enemies,
        "bullets": bullets,
        "orbs": orbs,
        "items": items,
        "effects": effects,
        "floating_texts": floating_texts,
        "wave": wave,
        "chapter": chapter,
        "kills": kills,
        "next_wave_kills": next_wave_kills,
        "spawn_timer": spawn_timer,
        "boss_spawned_waves": boss_spawned_waves,
        "message": message,
        "message_until": message_until,
        "rest_end_time": 0,
        "pending_day_message": "",
        "state": "start",
    }


# -----------------------------
# 메인 루프
# -----------------------------
def main():
    game = reset_game()
    running = True

    while running:
        dt = clock.tick(FPS)
        now = pygame.time.get_ticks()

        player = game["player"]
        enemies = game["enemies"]
        bullets = game["bullets"]
        orbs = game["orbs"]
        items = game["items"]
        effects = game["effects"]
        floating_texts = game["floating_texts"]

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_ESCAPE:
                    running = False

                if game["state"] == "start" and event.key == pygame.K_RETURN:
                    game["state"] = "playing"

                if game["state"] == "gameover" and event.key == pygame.K_r:
                    game = reset_game()
                    game["state"] = "playing"

        if game["state"] == "start":
            draw_start_screen(screen)
            continue

        if game["state"] == "playing":
            keys = pygame.key.get_pressed()
            player.move(keys)

            # 적 생성
            game["spawn_timer"] = spawn_enemy_if_needed(
                enemies,
                game["wave"],
                game["spawn_timer"],
                game["boss_spawned_waves"],
                dt
            )

            # 자동 공격
            auto_attack(player, enemies, bullets, effects)


            # 총알 충돌
            handle_bullet_collisions(bullets, enemies)

            # 적 이동 및 플레이어 충돌
            frozen = now < player.freeze_until
            for enemy in enemies:
                enemy.update(player, frozen=frozen)
                if distance(player.x, player.y, enemy.x, enemy.y) < player.radius + enemy.radius:
                    player.take_damage(enemy.damage)

            update_boss_patterns(enemies, player, effects)

            # 사망 적 제거 및 보상 생성
            new_kills, boss_killed = remove_dead_enemies(enemies, orbs, items, floating_texts, game["wave"])
            if new_kills > 0:
                game["kills"] += new_kills

            # Day 마지막 3웨이브에서는 보스를 잡으면 처치 수와 관계없이 바로 다음 Day로 넘어간다.
            if boss_killed and get_day_wave(game["wave"]) == WAVES_PER_DAY:
                game["kills"] = game["next_wave_kills"]
                boss_defeated_screen(screen, player, game["wave"], game["kills"])
                game["message"] = "보스 처치! 다음 Day로 이동합니다."
                game["message_until"] = pygame.time.get_ticks() + 2600

            # 웨이브 증가: 처치 수 기준
            if game["kills"] >= game["next_wave_kills"]:
                game["wave"] += 1
                new_chapter = get_chapter(game["wave"])
                game["next_wave_kills"] += 18 + game["wave"] * 5

                if new_chapter > game["chapter"]:
                    game["chapter"] = new_chapter

                    heal_amount = int(player.max_hp * DAY_END_HEAL_RATIO)
                    player.hp = min(player.max_hp, player.hp + heal_amount)
                    bonus_exp = DAY_BONUS_EXP_BASE + game["chapter"] * 80
                    player.exp += bonus_exp
                    reward_message = day_reward_screen(screen, player, game["chapter"], game["wave"], game["kills"])
                    game["message"] = f"Day {game['chapter']} 준비 시간! 체력 +{heal_amount}, EXP +{bonus_exp} / {reward_message}"

                    # Day가 바뀔 때는 잠시 쉬는 시간을 준다.
                    # 쉬는 시간 동안 남은 적과 총알을 정리하고, 적 생성/전투를 멈춘다.
                    enemies.clear()
                    bullets.clear()
                    effects.clear()
                    game["spawn_timer"] = 0
                    game["rest_end_time"] = pygame.time.get_ticks() + REST_DURATION_MS
                    game["pending_day_message"] = f"Day {game['chapter']} 시작! 좀비가 더 거세게 몰려옵니다."
                    game["state"] = "rest"
                    game["message_until"] = pygame.time.get_ticks() + REST_DURATION_MS
                else:
                    game["message"] = f"Wave {get_day_wave(game['wave'])}/{WAVES_PER_DAY} 시작! 좀비가 더 강하게 몰려옵니다."
                    game["message_until"] = now + 2300

            # 경험치 구슬 이동 및 획득
            for orb in orbs[:]:
                orb.update(player)
                if distance(player.x, player.y, orb.x, orb.y) < player.radius + orb.radius:
                    leveled = player.gain_exp(orb.amount)
                    if orb in orbs:
                        orbs.remove(orb)

                    if leveled:
                        result = level_up_screen(screen, player, game["chapter"], game["wave"], game["kills"], game["next_wave_kills"])

                        game["message"] = result
                        game["message_until"] = pygame.time.get_ticks() + 2800

            # 보급품 획득
            for item in items[:]:
                if distance(player.x, player.y, item.x, item.y) < player.radius + item.radius:
                    result = item.apply(player)
                    game["message"] = result
                    game["message_until"] = now + 2000
                    if item in items:
                        items.remove(item)

            # 이펙트 업데이트
            for effect in effects[:]:
                try:
                    effect.update(player)
                except TypeError:
                    effect.update()
                if effect.life <= 0:
                    effects.remove(effect)

            # 떠오르는 텍스트 업데이트
            for text in floating_texts[:]:
                text.update()
                if text.life <= 0:
                    floating_texts.remove(text)

            # 게임 오버
            if player.hp <= 0:
                game["state"] = "gameover"

        elif game["state"] == "rest":
            keys = pygame.key.get_pressed()
            player.move(keys)

            # 쉬는 시간에는 경험치 구슬과 아이템만 먹을 수 있다.
            for orb in orbs[:]:
                orb.update(player)
                if distance(player.x, player.y, orb.x, orb.y) < player.radius + orb.radius:
                    leveled = player.gain_exp(orb.amount)
                    if orb in orbs:
                        orbs.remove(orb)

                    if leveled:
                        result = level_up_screen(screen, player, game["chapter"], game["wave"], game["kills"], game["next_wave_kills"])
                        game["message"] = result
                        game["message_until"] = pygame.time.get_ticks() + 2800

            for item in items[:]:
                if distance(player.x, player.y, item.x, item.y) < player.radius + item.radius:
                    result = item.apply(player)
                    game["message"] = result
                    game["message_until"] = now + 2000
                    if item in items:
                        items.remove(item)


            for text in floating_texts[:]:
                text.update()
                if text.life <= 0:
                    floating_texts.remove(text)

            if now >= game["rest_end_time"]:
                game["state"] = "playing"
                game["message"] = game["pending_day_message"]
                game["message_until"] = now + 2300

        # -----------------------------
        # 그리기
        # -----------------------------
        draw_background(screen)

        # 캐릭터 주변 자석 범위 원은 숨김 처리했다.

        for orb in orbs:
            orb.draw(screen)

        for item in items:
            item.draw(screen)

        for bullet in bullets:
            bullet.draw(screen)

        for enemy in enemies:
            enemy.draw(screen)

        for effect in effects:
            effect.draw(screen)


        player.draw(screen)

        for text in floating_texts:
            text.draw(screen)

        draw_ui(screen, player, game["wave"], game["kills"], game["next_wave_kills"])

        if game["state"] == "rest":
            remaining = max(0, math.ceil((game["rest_end_time"] - now) / 1000))
            overlay = pygame.Surface((WIDTH, HEIGHT))
            overlay.set_alpha(95)
            overlay.fill((0, 0, 0))
            screen.blit(overlay, (0, 0))
            draw_text(screen, f"Day {game['chapter']} 준비 시간", TITLE_FONT, YELLOW, WIDTH // 2, HEIGHT // 2 - 50, center=True)
            draw_text(screen, f"{remaining}초 뒤 다음 Day 시작", FONT, WHITE, WIDTH // 2, HEIGHT // 2 + 10, center=True)
            draw_text(screen, "이동하면서 경험치와 아이템을 주울 수 있습니다", SMALL_FONT, CYAN, WIDTH // 2, HEIGHT // 2 + 48, center=True)
            draw_text(screen, "Day 종료 보상과 자동 회복/경험치 보너스가 적용되었습니다", SMALL_FONT, YELLOW, WIDTH // 2, HEIGHT // 2 + 76, center=True)

        if now < game["message_until"]:
            draw_text(screen, game["message"], FONT, YELLOW, WIDTH // 2, 22, center=True)

        if game["state"] == "gameover":
            draw_game_over(screen, player, game["wave"], game["kills"])

        pygame.display.flip()

    pygame.quit()
    sys.exit()


if __name__ == "__main__":
    main()
